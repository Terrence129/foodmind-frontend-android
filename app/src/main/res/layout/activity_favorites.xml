<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/placeholder_surface"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="36dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp"
    tools:context=".feature.favorites.ui.FavoritesActivity">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonBack"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/back"
        android:textColor="@color/home_ink"
        app:icon="@drawable/ic_arrow_back"
        app:iconTint="@color/home_ink" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/favorites_title"
        android:textColor="@color/home_ink"
        android:textSize="34sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:background="@drawable/bg_placeholder_card"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_home_favorite" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/coming_soon"
            android:textColor="@color/home_ink"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/favorites_placeholder"
            android:textColor="@color/home_ink_soft"
            android:textSize="16sp" />

    </LinearLayout>
</LinearLayout>
