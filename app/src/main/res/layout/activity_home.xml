<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".feature.home.ui.HomeActivity">

    <ImageView
        android:id="@+id/imageHomeBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/home_background_content_description"
        android:scaleType="centerCrop"
        android:src="@drawable/home_food_background" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="24dp"
        android:paddingTop="48dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:id="@+id/greetingGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_greeting_scrim"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            app:layout_constraintEnd_toStartOf="@+id/greetingEndGuide"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/textGreetingHello"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="cursive"
                android:includeFontPadding="false"
                android:text="@string/home_greeting_hello"
                android:textColor="@color/home_ink"
                android:textSize="42sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textGreetingUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="@color/home_ink"
                android:textSize="28sp"
                android:textStyle="bold"
                tools:text="test__huangqijun" />

        </LinearLayout>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/greetingEndGuide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.86" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRecommendations"
            android:layout_width="0dp"
            android:layout_height="178dp"
            android:layout_marginStart="-20dp"
            android:layout_marginEnd="-20dp"
            app:cardBackgroundColor="@color/home_recommendation_panel"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toTopOf="@id/homeBottomNavigation"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/greetingGroup"
            app:layout_constraintVertical_bias="0.62"
            app:strokeColor="@color/home_panel_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textRecommendationTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="20dp"
                    android:text="@string/home_recommendation_title"
                    android:textColor="@color/home_ink"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:id="@+id/recommendationScroll"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:fadingEdgeLength="32dp"
                    android:overScrollMode="never"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:requiresFadingEdge="horizontal"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/recommendationCards"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="132dp"
                            android:layout_height="104dp"
                            android:layout_marginEnd="12dp"
                            app:cardBackgroundColor="@color/home_dish_card"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/home_panel_stroke"
                            app:strokeWidth="2dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:maxLines="3"
                                android:padding="8dp"
                                android:text="@string/home_recommendation_first"
                                android:textAlignment="center"
                                android:textColor="@color/home_ink"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="132dp"
                            android:layout_height="104dp"
                            android:layout_marginEnd="12dp"
                            app:cardBackgroundColor="@color/home_dish_card"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/home_panel_stroke"
                            app:strokeWidth="2dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:maxLines="3"
                                android:padding="8dp"
                                android:text="@string/home_recommendation_second"
                                android:textAlignment="center"
                                android:textColor="@color/home_ink"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="132dp"
                            android:layout_height="104dp"
                            android:layout_marginEnd="12dp"
                            app:cardBackgroundColor="@color/home_dish_card"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/home_panel_stroke"
                            app:strokeWidth="2dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:maxLines="3"
                                android:padding="8dp"
                                android:text="@string/home_recommendation_third"
                                android:textAlignment="center"
                                android:textColor="@color/home_ink"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="132dp"
                            android:layout_height="104dp"
                            android:layout_marginEnd="12dp"
                            app:cardBackgroundColor="@color/home_dish_card"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/home_panel_stroke"
                            app:strokeWidth="2dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:maxLines="3"
                                android:padding="8dp"
                                android:text="@string/home_recommendation_fourth"
                                android:textAlignment="center"
                                android:textColor="@color/home_ink"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="132dp"
                            android:layout_height="104dp"
                            app:cardBackgroundColor="@color/home_dish_card"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/home_panel_stroke"
                            app:strokeWidth="2dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:maxLines="3"
                                android:padding="8dp"
                                android:text="@string/home_recommendation_fifth"
                                android:textAlignment="center"
                                android:textColor="@color/home_ink"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/homeBottomNavigation"
            android:layout_width="0dp"
            android:layout_height="84dp"
            android:layout_marginStart="-8dp"
            android:layout_marginEnd="-8dp"
            android:clipToPadding="false"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:id="@+id/buttonFavorites"
                android:layout_width="0dp"
                android:layout_height="76dp"
                android:layout_weight="1"
                android:background="@drawable/bg_home_nav_button"
                android:clickable="true"
                android:contentDescription="@string/home_favorites"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_home_favorite" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/buttonAddFood"
                android:layout_width="0dp"
                android:layout_height="76dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_weight="1.4"
                android:background="@drawable/bg_home_add_button"
                android:clickable="true"
                android:contentDescription="@string/home_add_food"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_home_add" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/home_add_food"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/buttonUserProfile"
                android:layout_width="0dp"
                android:layout_height="76dp"
                android:layout_weight="1"
                android:background="@drawable/bg_home_nav_button"
                android:clickable="true"
                android:contentDescription="@string/home_user_profile"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_home_user" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="2"
                    android:text="@string/home_user_profile"
                    android:textColor="@color/home_ink"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
